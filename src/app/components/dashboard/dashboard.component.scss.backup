// ── Page header ───────────────────────────────────────────────────────────────
.header-left {
  display: flex;
  flex-direction: column;
  gap: 2px;

  .header-date {
    font-size: 13px;
    color: #94A3B8;
    text-transform: capitalize;
  }
}

// ── Alert strip ───────────────────────────────────────────────────────────────
.alert-strip {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: #FFF7ED;
  border: 1px solid #FED7AA;
  border-left: 4px solid #F97316;
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 14px;
  color: #92400E;

  mat-icon { color: #F97316; flex-shrink: 0; }

  &.alert-critical {
    background: #FFF1F2;
    border-color: #FECDD3;
    border-left-color: #EF4444;
    color: #9F1239;
    mat-icon { color: #EF4444; }
  }
}

// ── KPI cards ─────────────────────────────────────────────────────────────────
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
  gap: 12px;
  margin-bottom: 16px;
}

.kpi-card {
  mat-card-content {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 14px !important;
  }

  .kpi-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    mat-icon { font-size: 22px; width: 22px; height: 22px; color: white; }
  }

  .kpi-value {
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
    color: #0F172A;
  }
  .kpi-label {
    font-size: 11px;
    color: #64748B;
    margin-top: 4px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  &.kpi-zero .kpi-icon { opacity: 0.35; }
  &.kpi-zero .kpi-value { color: #94A3B8; }

  &.kpi-health .kpi-icon { background: linear-gradient(135deg, #6366F1, #818CF8); }
  &.kpi-blocked .kpi-icon { background: linear-gradient(135deg, #EF4444, #F87171); }
  &.kpi-overdue .kpi-icon { background: linear-gradient(135deg, #F97316, #FB923C); }
  &.kpi-behind  .kpi-icon { background: linear-gradient(135deg, #F59E0B, #FCD34D); }
  &.kpi-active  .kpi-icon { background: linear-gradient(135deg, #3B82F6, #60A5FA); }
  &.kpi-done    .kpi-icon { background: linear-gradient(135deg, #10B981, #34D399); }
}

// ── Health text colours (used in global-health KPI) ───────────────────────────
.health-text-blocked { color: #EF4444 !important; }
.health-text-behind  { color: #F59E0B !important; }
.health-text-at-risk { color: #F97316 !important; }
.health-text-on-track { color: #10B981 !important; }
.health-text-done    { color: #10B981 !important; }

// ── Main 2-col grid ───────────────────────────────────────────────────────────
.main-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 14px;
  margin-bottom: 14px;

  @media (max-width: 960px) { grid-template-columns: 1fr; }
}

// ── Project health table ──────────────────────────────────────────────────────
.projects-health-card {
  mat-card-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: #0F172A;
    mat-icon { color: #6366F1; font-size: 20px; width: 20px; height: 20px; }
  }
}

.badge-warn {
  margin-left: 8px;
  padding: 2px 8px;
  border-radius: 99px;
  background: #FEF3C7;
  color: #92400E;
  font-size: 11px;
  font-weight: 600;
}

.ph-table {
  width: 100%;
  font-size: 13px;
}

.ph-thead {
  display: flex;
  padding: 8px 0;
  border-bottom: 2px solid #E2E8F0;
  font-size: 11px;
  font-weight: 700;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.ph-row {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #F1F5F9;
  transition: background 0.12s;

  &:last-child { border-bottom: none; }
  &:hover { background: #F8FAFC; }

  &.ph-row-blocked { background: #FFF1F2; border-left: 3px solid #EF4444; padding-left: 8px; }
  &.ph-row-behind  { background: #FFFBEB; border-left: 3px solid #F59E0B; padding-left: 8px; }
  &.ph-row-atrisk  { border-left: 3px solid #F97316; padding-left: 8px; }
}

.ph-col {
  padding: 0 8px;
  flex-shrink: 0;

  &.ph-col-name     { flex: 1; display: flex; align-items: center; gap: 8px; min-width: 0; }
  &.ph-col-health   { width: 110px; }
  &.ph-col-num      { width: 58px; text-align: center; }
  &.ph-col-progress { width: 200px; }
}

.project-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.project-name-text {
  font-weight: 500;
  color: #1E293B;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.num-done  { font-weight: 700; color: #10B981; }
.num-sep   { color: #CBD5E1; margin: 0 2px; }
.num-total { color: #64748B; }

.badge-blocked {
  display: inline-block;
  padding: 2px 7px;
  border-radius: 99px;
  background: #FEE2E2;
  color: #991B1B;
  font-size: 11px;
  font-weight: 700;
}
.badge-overdue {
  display: inline-block;
  padding: 2px 7px;
  border-radius: 99px;
  background: #FFEDD5;
  color: #7C2D12;
  font-size: 11px;
  font-weight: 700;
}

.mini-progress {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;

  .mini-track {
    flex: 1;
    height: 8px;
    background: #F1F5F9;
    border-radius: 4px;
    overflow: visible;
    position: relative;
  }

  .mini-fill {
    height: 100%;
    border-radius: 4px;
    position: absolute;
    left: 0;
    top: 0;
    &.actual { background: #6366F1; border-radius: 4px; }
  }

  .mini-expected-marker {
    position: absolute;
    top: -2px;
    width: 2px;
    height: 12px;
    background: #94A3B8;
    border-radius: 1px;
    transform: translateX(-50%);
  }

  .mini-pct {
    font-size: 12px;
    font-weight: 700;
    color: #1E293B;
    flex-shrink: 0;
    width: 32px;
    text-align: right;
  }

  .mini-exp-pct {
    font-size: 10px;
    color: #94A3B8;
    white-space: nowrap;
  }
}

// ── Health chip ───────────────────────────────────────────────────────────────
.health-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;

  mat-icon { font-size: 13px; width: 13px; height: 13px; }

  &.health-blocked  { background: #FEE2E2; color: #991B1B; mat-icon { color: #EF4444; } }
  &.health-behind   { background: #FEF3C7; color: #78350F; mat-icon { color: #F59E0B; } }
  &.health-at-risk  { background: #FFEDD5; color: #7C2D12; mat-icon { color: #F97316; } }
  &.health-on-track { background: #D1FAE5; color: #064E3B; mat-icon { color: #10B981; } }
  &.health-done     { background: #D1FAE5; color: #064E3B; mat-icon { color: #10B981; } }
}

// ── Member health panel ───────────────────────────────────────────────────────
.members-card {
  mat-card-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: #0F172A;
    mat-icon { color: #6366F1; font-size: 20px; width: 20px; height: 20px; }
  }
}

.member-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid #F1F5F9;

  &:last-child { border-bottom: none; }
  &.member-blocked { background: #FFF1F2; border-radius: 6px; padding: 8px; margin-bottom: 4px; border-bottom: none; }
  &.member-behind  { background: #FFFBEB; border-radius: 6px; padding: 8px; margin-bottom: 4px; border-bottom: none; }
}

.member-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  color: white;
  flex-shrink: 0;

  &.health-bg-blocked  { background: linear-gradient(135deg, #EF4444, #F87171); }
  &.health-bg-behind   { background: linear-gradient(135deg, #F59E0B, #FCD34D); }
  &.health-bg-at-risk  { background: linear-gradient(135deg, #F97316, #FB923C); }
  &.health-bg-on-track { background: linear-gradient(135deg, #10B981, #34D399); }
  &.health-bg-done     { background: linear-gradient(135deg, #10B981, #34D399); }
}

.member-info {
  flex: 1;
  min-width: 0;

  .member-name {
    font-weight: 600;
    font-size: 13px;
    color: #0F172A;
    margin-bottom: 4px;
  }

  .member-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 4px;
  }
}

.ms-chip {
  padding: 2px 6px;
  border-radius: 99px;
  font-size: 10px;
  font-weight: 600;

  &.ms-blocked { background: #FEE2E2; color: #991B1B; }
  &.ms-overdue { background: #FFEDD5; color: #7C2D12; }
  &.ms-behind  { background: #FEF3C7; color: #78350F; }
  &.ms-ok      { background: #D1FAE5; color: #064E3B; }
}

.member-worst-tasks {
  display: flex;
  flex-direction: column;
  gap: 2px;

  .worst-task-badge {
    font-size: 11px;
    color: #64748B;
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 4px;
    padding: 1px 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
}

.member-progress {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;

  .mp-pct  { font-size: 15px; font-weight: 700; color: #0F172A; }
  .mp-label { font-size: 10px; color: #94A3B8; }
}

// ── Critical tasks card ───────────────────────────────────────────────────────
.critical-card {
  margin-bottom: 14px;

  mat-card-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: #0F172A;
    mat-icon { color: #EF4444; font-size: 20px; width: 20px; height: 20px; }
  }
}

.badge-critical {
  margin-left: 4px;
  padding: 2px 8px;
  border-radius: 99px;
  background: #FEE2E2;
  color: #991B1B;
  font-size: 11px;
  font-weight: 700;
}

.ct-table {
  width: 100%;
  font-size: 13px;
  overflow-x: auto;
}

.ct-thead {
  display: flex;
  padding: 8px 0;
  border-bottom: 2px solid #E2E8F0;
  font-size: 11px;
  font-weight: 700;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.ct-row {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #F1F5F9;
  transition: background 0.12s;
  &:last-child { border-bottom: none; }
  &:hover { background: #F8FAFC; }

  &.severity-4 { background: #FFF1F2; }
  &.severity-3 { background: #FFF8F0; }
}

.ct-col {
  padding: 0 8px;
  flex-shrink: 0;

  &.ct-col-sev      { width: 32px; display: flex; align-items: center; justify-content: center; }
  &.ct-col-task     { flex: 1; display: flex; flex-direction: column; min-width: 160px; }
  &.ct-col-project  { width: 130px; display: flex; align-items: center; gap: 6px; }
  &.ct-col-assignee { width: 120px; color: #475569; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  &.ct-col-date     { width: 80px; }
  &.ct-col-pct      { width: 60px; text-align: right; font-weight: 600; color: #334155; }
  &.ct-col-lag      { width: 55px; text-align: right; }
  &.ct-col-reason   { width: 100px; }
}

.task-link {
  color: #1E293B;
  text-decoration: none;
  font-weight: 500;
  &:hover { color: #6366F1; text-decoration: underline; }
}

.ct-desc {
  font-size: 11px;
  color: #94A3B8;
  margin-top: 2px;
}

.ct-project-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.ct-project-name {
  color: #475569;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sev-icon {
  font-size: 18px;
  width: 18px;
  height: 18px;
  &.reason-blocked { color: #EF4444; }
  &.reason-overdue { color: #F97316; }
  &.reason-behind  { color: #F59E0B; }
  &.reason-at-risk { color: #CBD5E1; }
}

.overdue-text { color: #DC2626; font-weight: 600; }

.lag-behind { color: #EF4444; font-weight: 700; }

.reason-chip {
  display: inline-block;
  padding: 2px 7px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;

  &.reason-blocked { background: #FEE2E2; color: #991B1B; }
  &.reason-overdue { background: #FFEDD5; color: #7C2D12; }
  &.reason-behind  { background: #FEF3C7; color: #78350F; }
  &.reason-at-risk { background: #F1F5F9; color: #475569; }
}

// ── MS Project tree (expansion panel) ────────────────────────────────────────
.tree-panel {
  margin-bottom: 14px;
  border-radius: 10px !important;

  mat-panel-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: #0F172A;
    mat-icon { color: #6366F1; font-size: 20px; width: 20px; height: 20px; }
  }

  .tree-count {
    font-size: 12px;
    color: #94A3B8;
    font-weight: 400;
  }
}

.tree-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0 16px;

  button:last-child { margin-left: auto; }
}

// ── Gantt table (shared with old structure) ───────────────────────────────────
.gantt-table {
  width: 100%;
  overflow-x: auto;
  font-size: 13px;
}

.gcol {
  padding: 0 10px;
  display: flex;
  align-items: center;
  flex-shrink: 0;

  &.gcol-name     { flex: 1; min-width: 240px; }
  &.gcol-status   { width: 120px; }
  &.gcol-priority { width: 90px; }
  &.gcol-date     { width: 88px; color: #475569; font-size: 12px; }
  &.gcol-assignee { width: 130px; }
  &.gcol-progress { width: 210px; }
}

.gantt-thead {
  display: flex;
  background: #F8FAFC;
  border-bottom: 2px solid #E2E8F0;
  position: sticky;
  top: 0;
  z-index: 2;

  .gcol {
    padding: 10px 10px;
    font-size: 11px;
    font-weight: 700;
    color: #64748B;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
}

.gantt-row {
  display: flex;
  align-items: center;
  min-height: 48px;
  border-bottom: 1px solid #F1F5F9;
  transition: background 0.15s;

  &:hover { background: #F8FAFC; }
  &:last-child { border-bottom: none; }

  &.gantt-row-parent {
    background: #F8FAFC;
    border-left: 3px solid #6366F1;
    font-weight: 600;
    &:hover { background: #F1F5F9; }
  }

  &.gantt-row-overdue {
    border-left: 3px solid #EF4444;
    background: #FFF8F8;
    &:hover { background: #FEF2F2; }
  }

  &.gantt-row-done {
    opacity: 0.65;
    .task-title { text-decoration: line-through; color: #94A3B8; }
  }
}

.name-cell {
  display: flex;
  align-items: flex-start;
  width: 100%;
  padding: 6px 0;

  .expand-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: 4px;
    margin-top: 2px;
    border-radius: 4px;
    color: #64748B;

    &:hover { background: #E2E8F0; }
    mat-icon { font-size: 16px; width: 16px; height: 16px; }
  }

  .leaf-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #CBD5E1;
    flex-shrink: 0;
    margin: 6px 8px 0 6px;
  }

  .name-text {
    display: flex;
    flex-direction: column;
    min-width: 0;

    .task-title {
      font-weight: 500;
      color: #0F172A;
      white-space: normal;
      word-break: break-word;
      line-height: 1.4;
      &.parent-title { font-weight: 700; font-size: 13.5px; }
    }

    .task-desc {
      font-size: 11px;
      color: #94A3B8;
      margin-top: 2px;
      line-height: 1.4;
    }
  }
}

.derived-text { color: #64748B; font-style: italic; font-size: 12px; }
.no-value     { color: #CBD5E1; }

.due-text {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  &.overdue {
    color: #DC2626;
    font-weight: 600;
    .overdue-icon { font-size: 12px; width: 12px; height: 12px; }
  }
}

.assignee-text {
  font-size: 12px;
  color: #475569;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.progress-cell {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;

  .pbar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pbar-row {
    display: flex;
    align-items: center;
    gap: 4px;

    .pbar-label { font-size: 10px; color: #94A3B8; width: 22px; text-align: right; flex-shrink: 0; }

    .pbar-track {
      flex: 1;
      height: 6px;
      background: #F1F5F9;
      border-radius: 3px;
      overflow: hidden;
    }

    .pbar-fill {
      height: 100%;
      border-radius: 3px;
      transition: width 0.3s ease;
      &.actual   { background: #6366F1; }
      &.expected { background: #CBD5E1; }
      &.pbar-parent { background: #818CF8; }
    }

    .pbar-pct { font-size: 10px; color: #475569; width: 28px; text-align: right; flex-shrink: 0; font-weight: 600; }
  }

  .progress-icon {
    font-size: 16px;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    cursor: default;
    &.on-track { color: #10B981; }
    &.at-risk  { color: #F59E0B; }
    &.behind   { color: #EF4444; }
    &.done     { color: #10B981; }
    &.no-date  { color: #CBD5E1; }
  }
}

.gantt-empty {
  text-align: center;
  padding: 48px;
  color: #94A3B8;
  font-size: 14px;
  a { color: #6366F1; text-decoration: none; &:hover { text-decoration: underline; } }
}

.empty-state {
  text-align: center;
  padding: 32px;
  color: #94A3B8;
  font-size: 14px;
}
